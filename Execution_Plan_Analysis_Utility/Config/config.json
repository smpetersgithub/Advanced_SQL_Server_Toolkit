{
  "paths": {
    "logs_dir": "Logs",
    "output_dir": "Output",
    "config_dir": "Config"
  },
  "files": {
    "plan_config_file": "execution-plan-config.json",
    "json_output_file": "execution_plan_comparison_analysis_json.json",
    "json_single_plan_output_file": "execution_plan_single_analysis_json.json"
  },
  "logging": {
    "analysis_log_file": "log_01_analyze_execution_plans",
    "export_log_file": "log_02_export_to_excel",
    "single_plan_analysis_log_file": "log_03_analyze_single_plan",
    "single_plan_export_log_file": "log_04_export_single_plan_to_excel",
    "log_format": "%(asctime)s [%(levelname)s] %(message)s",
    "log_level": "INFO",
    "timestamp_format": "%Y%m%d_%H%M%S",
    "analysis_timestamp_format": "%Y-%m-%d %H:%M:%S",
    "log_filemode": "w"
  },
  "excel": {
    "header_color": "366092",
    "header_font_color": "FFFFFF",
    "header_font_size": 11,
    "excel_engine": "openpyxl",
    "max_sheet_name_length": 31
  }
}


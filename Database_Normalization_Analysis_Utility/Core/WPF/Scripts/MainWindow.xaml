<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Normalization Analysis Utility"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#f4f4f4"
        Icon="../Assets/icons8-goldfish-ico.ico">

    <!-- Window Resources for Styles -->
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6BA3E8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2E7DD1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6BA3E8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2E7DD1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Background="White" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,5">
                <Image Source="../Assets/icons8-goldfish-512.png" Width="64" Height="64" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="Database Normalization Analysis Utility"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>
            <TextBlock Text="Last Updated: 2026-04-02"
                       FontSize="10"
                       Foreground="#666666"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,10,0"/>
        </Grid>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#4A90E2" Padding="5" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                <!-- Analysis Section -->
                <Border BorderBrush="#6BA3E8" BorderThickness="0,0,1,0" Padding="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnRunFullAnalysis"
                                ToolTip="Run Full Analysis (All Steps)"
                                Style="{StaticResource ToolbarButtonStyle}">
                            <Image Source="C:\Advanced_SQL_Server_Toolkit\Database_Normalization_Analysis_Utility\Core\WPF\Assets\icons8-play-button-50.png" Width="32" Height="32"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- File Management Section -->
                <Border BorderBrush="#6BA3E8" BorderThickness="0,0,1,0" Padding="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnOpenOutputFolder"
                                ToolTip="Open Output Folder"
                                Style="{StaticResource ToolbarButtonStyle}">
                            <Image Source="C:\Advanced_SQL_Server_Toolkit\Database_Normalization_Analysis_Utility\Core\WPF\Assets\icons8-opened-folder-50.png" Width="32" Height="32"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Delete Section -->
                <Border BorderBrush="#6BA3E8" BorderThickness="0,0,1,0" Padding="5,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnClearOutputFolder"
                                ToolTip="Clear Output Folder"
                                Style="{StaticResource ToolbarButtonStyle}">
                            <Image Source="C:\Advanced_SQL_Server_Toolkit\Execution_Plan_Analysis_Utility\Core\WPF\Assets\icons8-delete-50.png" Width="32" Height="32"/>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <TabControl Grid.Row="2" Margin="10,0,10,10">

            <!-- Analysis Tab -->
            <TabItem Header="📊 Analysis">
                <Border BorderBrush="Black" BorderThickness="1" Padding="10" Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Database Normalization Analysis Configuration"
                                       FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                            <!-- Action Buttons at Top -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <!-- Save Configuration Button -->
                                <Button x:Name="btnSaveConfig"
                                        Content="💾 Save Configuration"
                                        Padding="20,10"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        Background="#3498DB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2980B9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Determine Columns and Keys Button -->
                                <Button x:Name="btnPopulateColumns"
                                        Content="📋 Determine Columns and Keys"
                                        Padding="20,10"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        Background="#3498DB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2980B9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Run Full Analysis Button -->
                                <Button x:Name="btnRunFullAnalysisConfig"
                                        Content="▶️ Run Full Analysis"
                                        Padding="20,10"
                                        FontSize="14"
                                        FontWeight="Normal"
                                        Background="#3498DB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2980B9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Table Analysis Section -->
                            <Border BorderBrush="#3498DB" BorderThickness="2" Padding="15" Margin="0,0,0,15" Background="#F8F9FA">
                                <StackPanel>
                                    <TextBlock Text="📋 Table Analysis Settings"
                                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"
                                               Foreground="#2C3E50"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Table Name -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Table Name:"
                                                   VerticalAlignment="Center" Margin="0,5"/>
                                        <TextBox x:Name="txtTableName" Grid.Row="0" Grid.Column="1"
                                                 Margin="5" Padding="5"/>

                                        <!-- Columns -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Columns:"
                                                   VerticalAlignment="Top" Margin="0,10,0,5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                            <TextBlock Text="Enter column names (one per line):"
                                                       FontStyle="Italic" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBox x:Name="txtColumns"
                                                     Height="150"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     FontFamily="Consolas"
                                                     Padding="5"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Keys Section -->
                            <Border BorderBrush="#3498DB" BorderThickness="2" Padding="15" Margin="0,0,0,15" Background="#F8F9FA">
                                <StackPanel>
                                    <TextBlock Text="🔑 Keys"
                                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"
                                               Foreground="#2C3E50"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Primary Key -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Primary Key:"
                                                   VerticalAlignment="Center" Margin="0,5"/>
                                        <TextBox x:Name="txtPrimaryKey" Grid.Row="0" Grid.Column="1"
                                                 Margin="5" Padding="5" IsReadOnly="True" Background="#EEEEEE"/>

                                        <!-- Unique Key -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Unique Key:"
                                                   VerticalAlignment="Center" Margin="0,5"/>
                                        <TextBox x:Name="txtUniqueKey" Grid.Row="1" Grid.Column="1"
                                                 Margin="5" Padding="5" IsReadOnly="True" Background="#EEEEEE"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- Connection Tab -->
            <TabItem Header="🔌 Connection" x:Name="ConnectionTab">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Padding="20">
                        <GroupBox.Header>
                            <TextBlock Text="Database Connection Settings" FontWeight="Bold" FontSize="14"/>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Server -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Server:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtServer" Text="localhost" Margin="0,0,0,10" Height="30" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

                            <!-- Database -->
                            <Label Grid.Row="1" Grid.Column="0" Content="Database:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDatabase" Margin="0,0,0,10" Height="30" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

                            <!-- Username -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Username:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtUsername" Margin="0,0,0,10" Height="30" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

                            <!-- Password -->
                            <Label Grid.Row="3" Grid.Column="0" Content="Password:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtPassword" Margin="0,0,0,10" Height="30" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

                            <!-- Buttons -->
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="btnTestConnection"
                                        Content="🔍 Test Connection"
                                        Style="{StaticResource ModernButton}"
                                        Width="180"
                                        Height="35"
                                        Margin="0,0,10,0"/>
                                <Button x:Name="btnSaveConnection"
                                        Content="💾 Save Configuration"
                                        Style="{StaticResource ModernButton}"
                                        Width="180"
                                        Height="35"/>
                            </StackPanel>

                            <!-- Connection Status -->
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtConnectionStatus"
                                       Text="Not tested"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       Margin="0,10,0,0"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Configuration Tab -->
            <TabItem Header="⚙️ Configuration" x:Name="ConfigTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Config Selector -->
                    <ComboBox Grid.Row="0"
                              x:Name="cmbConfigFiles"
                              Height="30"
                              Margin="0,0,0,10"
                              VerticalContentAlignment="Center"
                              Padding="5,0,0,0"
                              FontSize="13"/>

                    <!-- Config Display -->
                    <GroupBox Grid.Row="1" Padding="10" Margin="0,0,0,10">
                        <TextBox x:Name="txtConfigContent"
                                 IsReadOnly="False"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="White"
                                 Padding="10"/>
                    </GroupBox>

                    <!-- Config File Path Display -->
                    <TextBlock Grid.Row="2" x:Name="txtConfigFilePath" FontFamily="Consolas" FontSize="11" Foreground="#666666" Margin="0,0,0,5"/>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1" x:Name="btnRefreshConfig" Content="🔄 Refresh" Style="{StaticResource ModernButton}" Width="150" Height="35" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" x:Name="btnCopyConfigPath" Content="📋 Copy Path" Style="{StaticResource ModernButton}" Width="150" Height="35" Margin="0,0,10,0"/>
                        <Button Grid.Column="3" x:Name="btnSaveConfigFile" Content="💾 Save Config" Style="{StaticResource ModernButton}" Width="150" Height="35"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Output Log Tab -->
            <TabItem Header="📝 Output Log">
                <Border BorderBrush="Black" BorderThickness="1" Padding="10" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Analysis Output"
                                       FontWeight="Bold" FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="btnClearLog"
                                    Content="Clear Log"
                                    Margin="15,0,0,0"
                                    Padding="10,5"
                                    Background="#E74C3C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            <Button x:Name="btnOpenLogsFolder"
                                    Content="📂 Open Logs Folder"
                                    Margin="10,0,0,0"
                                    Padding="10,5"
                                    Background="#3498DB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <TextBox x:Name="txtOutputLog"
                                 Grid.Row="1"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Background="#1E1E1E"
                                 Foreground="#D4D4D4"
                                 Padding="5"/>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtStatus"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <!-- Spinning Progress Indicator -->
                <Grid x:Name="progressSpinner"
                      Grid.Column="1"
                      Width="16"
                      Height="16"
                      Margin="0,0,10,0"
                      Visibility="Collapsed"
                      VerticalAlignment="Center">
                    <Ellipse Fill="Transparent"
                             Stroke="#3498DB"
                             StrokeThickness="2"
                             StrokeDashArray="3,1">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="spinnerRotation" CenterX="8" CenterY="8"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="spinnerRotation"
                                                       Storyboard.TargetProperty="Angle"
                                                       From="0"
                                                       To="360"
                                                       Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Grid>

                <TextBlock x:Name="txtProgress"
                           Grid.Column="2"
                           Text=""
                           Foreground="#3498DB"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
